---
import { events, rulers, type TimelineItem } from "../data/timeline";

const TIMELINE_START_YEAR = 500;
const TIMELINE_END_YEAR = new Date().getFullYear();
const YEAR_SCALE_PX = 3;
const LABEL_GAP_PX = 14;
const LABEL_HEIGHT_ESTIMATE_PX = 138;
const TIMELINE_SCALE_HEIGHT = (TIMELINE_END_YEAR - TIMELINE_START_YEAR) * YEAR_SCALE_PX;

type TimelineLane = "rulers" | "events";

type PlacedTimelineItem = TimelineItem & {
  endYear: number;
  labelTop: number;
  rangeHeight: number;
  startYear: number;
  top: number;
};

function parseYearToken(token: string | undefined, isRangeEnd = false) {
  if (!token) {
    return undefined;
  }

  const normalized = token.trim().toLowerCase();
  if (normalized.includes("present")) {
    return TIMELINE_END_YEAR;
  }

  const match = normalized.match(/\d{3,4}/);
  if (!match) {
    return undefined;
  }

  const year = Number(match[0]);
  return isRangeEnd && /\d{3,4}s\b/.test(normalized) ? year + 9 : year;
}

function getYearRange(date: string) {
  const parts = date.replace(/^c\.\s*/i, "").split("-");
  const startYear = parseYearToken(parts[0]) ?? TIMELINE_START_YEAR;
  const endYear = parseYearToken(parts[1], true) ?? startYear;

  return {
    startYear: Math.max(TIMELINE_START_YEAR, startYear),
    endYear: Math.min(TIMELINE_END_YEAR, Math.max(startYear, endYear)),
  };
}

function placeTimelineItems(items: TimelineItem[], lane: TimelineLane): PlacedTimelineItem[] {
  let previousLabelBottom = 0;

  return items
    .map((item) => {
      const { startYear, endYear } = getYearRange(item.date);

      return {
        item,
        endYear,
        startYear,
      };
    })
    .sort((first, second) => first.startYear - second.startYear || first.endYear - second.endYear)
    .map(({ item, startYear, endYear }) => {
      const top = (startYear - TIMELINE_START_YEAR) * YEAR_SCALE_PX;
      const rangeHeight = Math.max((endYear - startYear) * YEAR_SCALE_PX, lane === "rulers" ? 10 : 8);
      const labelTop = Math.max(top - 8, previousLabelBottom + LABEL_GAP_PX);
      previousLabelBottom = labelTop + LABEL_HEIGHT_ESTIMATE_PX;

      return {
        ...item,
        endYear,
        labelTop,
        rangeHeight,
        startYear,
        top,
      };
    });
}

const placedRulers = placeTimelineItems(rulers, "rulers");
const placedEvents = placeTimelineItems(events, "events");
const timelineCanvasHeight = Math.max(
  TIMELINE_SCALE_HEIGHT,
  ...[...placedRulers, ...placedEvents].map((item) => item.labelTop + LABEL_HEIGHT_ESTIMATE_PX),
);
const yearMarks = Array.from(
  { length: Math.floor((TIMELINE_END_YEAR - TIMELINE_START_YEAR) / 100) + 1 },
  (_, index) => TIMELINE_START_YEAR + index * 100,
).concat((TIMELINE_END_YEAR - TIMELINE_START_YEAR) % 100 === 0 ? [] : [TIMELINE_END_YEAR]);
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="A bilingual side-by-side timeline of Russian history, with rulers and major events from early Slavic origins to the present."
    />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("timeline-language");
          const initial = stored === "ru" ? "ru" : "en";
          document.documentElement.dataset.lang = initial;
          document.documentElement.lang = initial;
        } catch {
          document.documentElement.dataset.lang = "en";
          document.documentElement.lang = "en";
        }
      })();
    </script>
    <title>Russia History Timeline</title>
  </head>
  <body>
    <header class="hero">
      <nav class="topbar" aria-label="Language">
        <a class="brand" href="/" aria-label="Russia History Timeline">
          <span>RHT</span>
        </a>
        <div class="language-toggle" role="group" aria-label="Language switcher">
          <button type="button" data-set-lang="en" aria-pressed="true">EN</button>
          <button type="button" data-set-lang="ru" aria-pressed="false">RU</button>
        </div>
        <script is:inline>
          (() => {
            const lang = document.documentElement.dataset.lang === "ru" ? "ru" : "en";
            document.querySelectorAll("[data-set-lang]").forEach((button) => {
              button.setAttribute("aria-pressed", String(button.dataset.setLang === lang));
            });
          })();
        </script>
      </nav>

      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">
            <span class="lang-en">Origins to present</span>
            <span class="lang-ru">От истоков до современности</span>
          </p>
          <h1>
            <span class="lang-en">History of Russia, before and after the name.</span>
            <span class="lang-ru">История России: до имени и после него.</span>
          </h1>
          <p class="lede">
            <span class="lang-en">
              Two parallel timelines: rulers and major events, from early Slavic worlds and Rus' trade routes to the Russian Federation.
            </span>
            <span class="lang-ru">
              Две параллельные линии времени: правители и ключевые события, от ранних славянских миров и путей Руси до Российской Федерации.
            </span>
          </p>
          <div class="stats" aria-label="Timeline summary">
            <div>
              <strong>{rulers.length}</strong>
              <span>
                <span class="lang-en">ruler entries</span>
                <span class="lang-ru">записей о правителях</span>
              </span>
            </div>
            <div>
              <strong>{events.length}</strong>
              <span>
                <span class="lang-en">event entries</span>
                <span class="lang-ru">событий</span>
              </span>
            </div>
          </div>
        </div>

        <figure class="hero-media">
          <img
            src="/varangians.jpg"
            alt="Public-domain historical painting of the calling of the Varangians"
            loading="eager"
          />
          <figcaption>
            <span class="lang-en">Calling of the Varangians, public-domain reproduction via Wikimedia Commons.</span>
            <span class="lang-ru">Призвание варягов, репродукция общественного достояния через Wikimedia Commons.</span>
          </figcaption>
        </figure>
      </div>
    </header>

    <main>
      <section class="intro" aria-labelledby="timeline-title">
        <div>
          <p class="eyebrow">
            <span class="lang-en">Parallel scan</span>
            <span class="lang-ru">Параллельный обзор</span>
          </p>
          <h2 id="timeline-title">
            <span class="lang-en">Rulers beside the moments that changed the region.</span>
            <span class="lang-ru">Правители рядом с событиями, изменившими регион.</span>
          </h2>
        </div>
        <p>
          <span class="lang-en">
            The left timeline follows authority: tribes, princes, tsars, emperors, Soviet leaders, and presidents. The right timeline follows turning points in statehood, war, religion, reform, and collapse.
          </span>
          <span class="lang-ru">
            Левая линия показывает власть: племена, князей, царей, императоров, советских лидеров и президентов. Правая линия показывает переломы в государственности, войне, религии, реформах и распаде.
          </span>
        </p>
      </section>

      <section
        class="timeline-shell"
        aria-label="Historical timeline"
        style={`--scale-height: ${TIMELINE_SCALE_HEIGHT}px; --canvas-height: ${timelineCanvasHeight}px;`}
      >
        <div class="timeline-head-grid">
          <div class="axis-head" aria-hidden="true"></div>
          <div class="column-head rulers-head">
            <span class="label-dot"></span>
            <h2>
              <span class="lang-en">Rulers</span>
              <span class="lang-ru">Правители</span>
            </h2>
          </div>
          <div class="column-head events-head">
            <span class="label-dot"></span>
            <h2>
              <span class="lang-en">Major Events</span>
              <span class="lang-ru">Ключевые события</span>
            </h2>
          </div>
        </div>

        <div class="timeline-scroll">
          <div class="timeline-content">
            <div class="scaled-timeline">
            <div class="year-axis" aria-hidden="true">
              {
                yearMarks.map((year) => (
                  <div class="year-mark" style={`--top: ${(year - TIMELINE_START_YEAR) * YEAR_SCALE_PX}px`}>
                    <span>{year}</span>
                  </div>
                ))
              }
            </div>

            <div class="timeline-lane rulers-lane">
              {
                placedRulers.map((item, index) => (
                  <article
                    class="timeline-item rulers"
                    style={`--top: ${item.top}px; --label-top: ${item.labelTop}px; --range-height: ${item.rangeHeight}px; --delay: ${index * 24}ms`}
                  >
                    <span class="range-bar" aria-hidden="true"></span>
                    <span class="connector" aria-hidden="true"></span>
                    <div class="entry">
                      <div class="date">{item.date}</div>
                      <p class="era">
                        <span class="lang-en">{item.era.en}</span>
                        <span class="lang-ru">{item.era.ru}</span>
                      </p>
                      <h3>
                        <span class="lang-en">{item.title.en}</span>
                        <span class="lang-ru">{item.title.ru}</span>
                      </h3>
                      <p>
                        <span class="lang-en">{item.description.en}</span>
                        <span class="lang-ru">{item.description.ru}</span>
                      </p>
                    </div>
                  </article>
                ))
              }
            </div>

            <div class="timeline-lane events-lane">
              {
                placedEvents.map((item, index) => (
                  <article
                    class="timeline-item events"
                    style={`--top: ${item.top}px; --label-top: ${item.labelTop}px; --range-height: ${item.rangeHeight}px; --delay: ${index * 24}ms`}
                  >
                    <span class="range-bar" aria-hidden="true"></span>
                    <span class="connector" aria-hidden="true"></span>
                    <div class="entry">
                      <div class="date">{item.date}</div>
                      <p class="era">
                        <span class="lang-en">{item.era.en}</span>
                        <span class="lang-ru">{item.era.ru}</span>
                      </p>
                      <h3>
                        <span class="lang-en">{item.title.en}</span>
                        <span class="lang-ru">{item.title.ru}</span>
                      </h3>
                      <p>
                        <span class="lang-en">{item.description.en}</span>
                        <span class="lang-ru">{item.description.ru}</span>
                      </p>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <p>
        <span class="lang-en">Built as an Astro static site for quick bilingual historical scanning.</span>
        <span class="lang-ru">Статический сайт Astro для быстрого двуязычного обзора истории.</span>
      </p>
    </footer>

    <script>
      const root = document.documentElement;
      const buttons = Array.from(document.querySelectorAll("[data-set-lang]"));
      const stored = localStorage.getItem("timeline-language");
      const initial = stored === "ru" ? "ru" : "en";

      function setLanguage(lang) {
        root.dataset.lang = lang;
        root.lang = lang;
        localStorage.setItem("timeline-language", lang);
        buttons.forEach((button) => {
          const active = button.dataset.setLang === lang;
          button.setAttribute("aria-pressed", String(active));
        });
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => setLanguage(button.dataset.setLang));
      });

      setLanguage(initial);
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --paper: #f4efe6;
    --paper-strong: #fffaf0;
    --ink: #22201d;
    --muted: #70685c;
    --line: rgba(41, 36, 29, 0.16);
    --red: #9f352c;
    --blue: #24495c;
    --shadow: 0 24px 80px rgba(50, 42, 31, 0.12);
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--paper);
    color: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(90deg, rgba(34, 32, 29, 0.035) 1px, transparent 1px) 0 0 / 44px 44px,
      linear-gradient(180deg, rgba(34, 32, 29, 0.03) 1px, transparent 1px) 0 0 / 44px 44px,
      var(--paper);
  }

  body::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background:
      radial-gradient(circle at 16% 10%, rgba(159, 53, 44, 0.14), transparent 27rem),
      radial-gradient(circle at 88% 4%, rgba(36, 73, 92, 0.12), transparent 24rem);
  }

  .lang-ru {
    display: none;
  }

  html[data-lang="ru"] .lang-en {
    display: none;
  }

  html[data-lang="ru"] .lang-ru {
    display: inline;
  }

  .hero,
  main,
  footer {
    width: min(100% - 32px, 1180px);
    margin: 0 auto;
  }

  .hero {
    min-height: calc(100dvh - 48px);
    padding: 24px 0 56px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 48px;
  }

  .brand {
    display: inline-grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    text-decoration: none;
    background: rgba(255, 250, 240, 0.72);
  }

  .brand span,
  .eyebrow,
  .date,
  .era,
  .stats strong {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0;
  }

  .brand span {
    font-size: 0.78rem;
  }

  .language-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 250, 240, 0.78);
  }

  button {
    min-width: 46px;
    border: 0;
    border-radius: 6px;
    padding: 10px 12px;
    color: var(--muted);
    background: transparent;
    font: inherit;
    font-size: 0.78rem;
    cursor: pointer;
    transition:
      transform 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  button:hover,
  button:focus-visible {
    color: var(--ink);
    outline: 2px solid rgba(159, 53, 44, 0.42);
    outline-offset: 2px;
  }

  button:active {
    transform: translateY(1px);
  }

  button[aria-pressed="true"] {
    color: var(--paper-strong);
    background: var(--ink);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.72fr);
    align-items: end;
    gap: clamp(28px, 5vw, 72px);
    padding-top: clamp(42px, 8vw, 96px);
  }

  .hero-copy {
    padding-bottom: clamp(8px, 3vw, 32px);
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--red);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 540;
    letter-spacing: 0;
  }

  h1 {
    max-width: 760px;
    font-size: clamp(3.2rem, 8vw, 7.4rem);
    line-height: 0.92;
  }

  .lede {
    max-width: 660px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.7vw, 1.32rem);
    line-height: 1.65;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 170px));
    gap: 12px;
    margin-top: 34px;
  }

  .stats div {
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  .stats strong {
    display: block;
    font-size: 1.35rem;
  }

  .stats span {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .hero-media {
    position: relative;
    margin: 0;
  }

  .hero-media::before {
    position: absolute;
    inset: 18px -18px -18px 18px;
    z-index: -1;
    border: 1px solid rgba(159, 53, 44, 0.32);
    content: "";
  }

  .hero-media img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: 1px solid rgba(34, 32, 29, 0.24);
    box-shadow: var(--shadow);
    filter: sepia(0.16) saturate(0.86);
  }

  figcaption {
    margin-top: 12px;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .intro {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(280px, 0.52fr);
    gap: clamp(24px, 5vw, 80px);
    padding: 64px 0 34px;
    border-top: 1px solid var(--line);
  }

  .intro h2 {
    max-width: 680px;
    font-size: clamp(2rem, 4vw, 4.2rem);
    line-height: 1;
  }

  .intro p:last-child {
    align-self: end;
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .timeline-shell {
    padding: 24px 0 88px;
  }

  .timeline-head-grid {
    position: sticky;
    top: 0;
    z-index: 5;
    display: grid;
    grid-template-columns: 78px repeat(2, minmax(0, 1fr));
    gap: 0 28px;
    padding: 24px 0 0;
    background: rgba(244, 239, 230, 0.9);
    backdrop-filter: blur(12px);
  }

  .column-head {
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 18px 0;
    background: transparent;
  }

  .axis-head {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .label-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--red);
  }

  .events-head .label-dot {
    background: var(--blue);
  }

  .column-head h2 {
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .timeline-scroll {
    overflow-x: auto;
    padding-bottom: 10px;
  }

  .timeline-content {
    min-width: 760px;
  }

  .scaled-timeline {
    position: relative;
    display: grid;
    grid-template-columns: 78px repeat(2, minmax(260px, 1fr));
    gap: 0 28px;
    min-height: var(--canvas-height);
    padding-top: 18px;
  }

  .year-axis {
    position: relative;
    min-height: var(--canvas-height);
  }

  .year-axis::before {
    position: absolute;
    top: 0;
    right: 16px;
    width: 1px;
    height: var(--scale-height);
    background: rgba(34, 32, 29, 0.24);
    content: "";
  }

  .year-mark {
    position: absolute;
    top: var(--top);
    right: 0;
    width: 100%;
    border-top: 1px solid rgba(34, 32, 29, 0.18);
  }

  .year-mark span {
    position: absolute;
    top: -0.68rem;
    right: 26px;
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0;
  }

  .timeline-lane {
    position: relative;
    min-height: var(--canvas-height);
    border-top: 1px solid rgba(34, 32, 29, 0.12);
  }

  .timeline-lane::before {
    position: absolute;
    top: 0;
    left: 10px;
    width: 1px;
    height: var(--scale-height);
    background: rgba(34, 32, 29, 0.16);
    content: "";
  }

  .timeline-item {
    position: absolute;
    top: var(--top);
    right: 0;
    left: 0;
    min-height: var(--range-height);
    opacity: 0;
    animation: rise-in 540ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay);
  }

  .range-bar {
    position: absolute;
    top: 0;
    left: 6px;
    width: 9px;
    height: var(--range-height);
    min-height: 8px;
    border-radius: 999px;
    background: var(--red);
    box-shadow: 0 0 0 4px rgba(159, 53, 44, 0.08);
  }

  .events .range-bar {
    background: var(--blue);
    box-shadow: 0 0 0 4px rgba(36, 73, 92, 0.08);
  }

  .connector {
    position: absolute;
    top: calc(var(--label-top) - var(--top) + 22px);
    left: 15px;
    width: 24px;
    height: 1px;
    background: rgba(34, 32, 29, 0.22);
  }

  .date {
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  .entry {
    position: absolute;
    top: calc(var(--label-top) - var(--top));
    right: 0;
    left: 38px;
    min-height: 124px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--red);
    border-radius: 8px;
    padding: 13px 16px 16px;
    background: rgba(255, 250, 240, 0.72);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .events .entry {
    border-left-color: var(--blue);
  }

  .timeline-item:hover .entry {
    transform: translateY(-2px);
    border-color: rgba(34, 32, 29, 0.3);
    background: var(--paper-strong);
  }

  .era {
    margin: 0 0 10px;
    color: var(--red);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .events .era {
    color: var(--blue);
  }

  .entry h3 {
    font-size: clamp(1.12rem, 1.55vw, 1.48rem);
    line-height: 1.1;
  }

  .entry p:last-child {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.52;
