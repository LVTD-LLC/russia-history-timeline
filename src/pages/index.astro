---
import { events, rulers } from "../data/timeline";
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="A bilingual side-by-side timeline of Russian history, with rulers and major events from early Slavic origins to the present."
    />
    <title>Russia History Timeline</title>
  </head>
  <body>
    <header class="hero">
      <nav class="topbar" aria-label="Language">
        <a class="brand" href="/" aria-label="Russia History Timeline">
          <span>RHT</span>
        </a>
        <div class="language-toggle" role="group" aria-label="Language switcher">
          <button type="button" data-set-lang="en" aria-pressed="true">EN</button>
          <button type="button" data-set-lang="ru" aria-pressed="false">RU</button>
        </div>
      </nav>

      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">
            <span class="lang-en">Origins to present</span>
            <span class="lang-ru">От истоков до современности</span>
          </p>
          <h1>
            <span class="lang-en">History of Russia, before and after the name.</span>
            <span class="lang-ru">История России: до имени и после него.</span>
          </h1>
          <p class="lede">
            <span class="lang-en">
              Two parallel timelines: rulers and major events, from early Slavic worlds and Rus' trade routes to the Russian Federation.
            </span>
            <span class="lang-ru">
              Две параллельные линии времени: правители и ключевые события, от ранних славянских миров и путей Руси до Российской Федерации.
            </span>
          </p>
          <div class="stats" aria-label="Timeline summary">
            <div>
              <strong>{rulers.length}</strong>
              <span>
                <span class="lang-en">ruler entries</span>
                <span class="lang-ru">записей о правителях</span>
              </span>
            </div>
            <div>
              <strong>{events.length}</strong>
              <span>
                <span class="lang-en">event entries</span>
                <span class="lang-ru">событий</span>
              </span>
            </div>
          </div>
        </div>

        <figure class="hero-media">
          <img
            src="/varangians.jpg"
            alt="Public-domain historical painting of the calling of the Varangians"
            loading="eager"
          />
          <figcaption>
            <span class="lang-en">Calling of the Varangians, public-domain reproduction via Wikimedia Commons.</span>
            <span class="lang-ru">Призвание варягов, репродукция общественного достояния через Wikimedia Commons.</span>
          </figcaption>
        </figure>
      </div>
    </header>

    <main>
      <section class="intro" aria-labelledby="timeline-title">
        <div>
          <p class="eyebrow">
            <span class="lang-en">Parallel scan</span>
            <span class="lang-ru">Параллельный обзор</span>
          </p>
          <h2 id="timeline-title">
            <span class="lang-en">Rulers beside the moments that changed the region.</span>
            <span class="lang-ru">Правители рядом с событиями, изменившими регион.</span>
          </h2>
        </div>
        <p>
          <span class="lang-en">
            The left timeline follows authority: tribes, princes, tsars, emperors, Soviet leaders, and presidents. The right timeline follows turning points in statehood, war, religion, reform, and collapse.
          </span>
          <span class="lang-ru">
            Левая линия показывает власть: племена, князей, царей, императоров, советских лидеров и президентов. Правая линия показывает переломы в государственности, войне, религии, реформах и распаде.
          </span>
        </p>
      </section>

      <section class="timeline-shell" aria-label="Historical timeline">
        <div class="column-head rulers-head">
          <span class="label-dot"></span>
          <h2>
            <span class="lang-en">Rulers</span>
            <span class="lang-ru">Правители</span>
          </h2>
        </div>
        <div class="column-head events-head">
          <span class="label-dot"></span>
          <h2>
            <span class="lang-en">Major Events</span>
            <span class="lang-ru">Ключевые события</span>
          </h2>
        </div>
        <div class="timeline-list rulers-list">
          {
            rulers.map((item, index) => (
              <article class="timeline-item rulers" style={`--delay: ${index * 24}ms`}>
                <div class="date">{item.date}</div>
                <div class="entry">
                  <p class="era">
                    <span class="lang-en">{item.era.en}</span>
                    <span class="lang-ru">{item.era.ru}</span>
                  </p>
                  <h3>
                    <span class="lang-en">{item.title.en}</span>
                    <span class="lang-ru">{item.title.ru}</span>
                  </h3>
                  <p>
                    <span class="lang-en">{item.description.en}</span>
                    <span class="lang-ru">{item.description.ru}</span>
                  </p>
                </div>
              </article>
            ))
          }
        </div>
        <div class="timeline-list events-list">
          {
            events.map((item, index) => (
              <article class="timeline-item events" style={`--delay: ${index * 24}ms`}>
                <div class="date">{item.date}</div>
                <div class="entry">
                  <p class="era">
                    <span class="lang-en">{item.era.en}</span>
                    <span class="lang-ru">{item.era.ru}</span>
                  </p>
                  <h3>
                    <span class="lang-en">{item.title.en}</span>
                    <span class="lang-ru">{item.title.ru}</span>
                  </h3>
                  <p>
                    <span class="lang-en">{item.description.en}</span>
                    <span class="lang-ru">{item.description.ru}</span>
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <footer>
      <p>
        <span class="lang-en">Built as an Astro static site for quick bilingual historical scanning.</span>
        <span class="lang-ru">Статический сайт Astro для быстрого двуязычного обзора истории.</span>
      </p>
    </footer>

    <script>
      const root = document.documentElement;
      const buttons = Array.from(document.querySelectorAll("[data-set-lang]"));
      const stored = localStorage.getItem("timeline-language");
      const initial = stored === "ru" ? "ru" : "en";

      function setLanguage(lang) {
        root.dataset.lang = lang;
        root.lang = lang;
        localStorage.setItem("timeline-language", lang);
        buttons.forEach((button) => {
          const active = button.dataset.setLang === lang;
          button.setAttribute("aria-pressed", String(active));
        });
      }

      buttons.forEach((button) => {
        button.addEventListener("click", () => setLanguage(button.dataset.setLang));
      });

      setLanguage(initial);
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --paper: #f4efe6;
    --paper-strong: #fffaf0;
    --ink: #22201d;
    --muted: #70685c;
    --line: rgba(41, 36, 29, 0.16);
    --red: #9f352c;
    --blue: #24495c;
    --shadow: 0 24px 80px rgba(50, 42, 31, 0.12);
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background: var(--paper);
    color: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(90deg, rgba(34, 32, 29, 0.035) 1px, transparent 1px) 0 0 / 44px 44px,
      linear-gradient(180deg, rgba(34, 32, 29, 0.03) 1px, transparent 1px) 0 0 / 44px 44px,
      var(--paper);
  }

  body::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background:
      radial-gradient(circle at 16% 10%, rgba(159, 53, 44, 0.14), transparent 27rem),
      radial-gradient(circle at 88% 4%, rgba(36, 73, 92, 0.12), transparent 24rem);
  }

  .lang-ru {
    display: none;
  }

  html[data-lang="ru"] .lang-en {
    display: none;
  }

  html[data-lang="ru"] .lang-ru {
    display: inline;
  }

  .hero,
  main,
  footer {
    width: min(100% - 32px, 1180px);
    margin: 0 auto;
  }

  .hero {
    min-height: calc(100dvh - 48px);
    padding: 24px 0 56px;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 48px;
  }

  .brand {
    display: inline-grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    text-decoration: none;
    background: rgba(255, 250, 240, 0.72);
  }

  .brand span,
  .eyebrow,
  .date,
  .era,
  .stats strong {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: 0;
  }

  .brand span {
    font-size: 0.78rem;
  }

  .language-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 250, 240, 0.78);
  }

  button {
    min-width: 46px;
    border: 0;
    border-radius: 6px;
    padding: 10px 12px;
    color: var(--muted);
    background: transparent;
    font: inherit;
    font-size: 0.78rem;
    cursor: pointer;
    transition:
      transform 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  button:hover,
  button:focus-visible {
    color: var(--ink);
    outline: 2px solid rgba(159, 53, 44, 0.42);
    outline-offset: 2px;
  }

  button:active {
    transform: translateY(1px);
  }

  button[aria-pressed="true"] {
    color: var(--paper-strong);
    background: var(--ink);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.72fr);
    align-items: end;
    gap: clamp(28px, 5vw, 72px);
    padding-top: clamp(42px, 8vw, 96px);
  }

  .hero-copy {
    padding-bottom: clamp(8px, 3vw, 32px);
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--red);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-weight: 540;
    letter-spacing: 0;
  }

  h1 {
    max-width: 760px;
    font-size: clamp(3.2rem, 8vw, 7.4rem);
    line-height: 0.92;
  }

  .lede {
    max-width: 660px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 1.7vw, 1.32rem);
    line-height: 1.65;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 170px));
    gap: 12px;
    margin-top: 34px;
  }

  .stats div {
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  .stats strong {
    display: block;
    font-size: 1.35rem;
  }

  .stats span {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .hero-media {
    position: relative;
    margin: 0;
  }

  .hero-media::before {
    position: absolute;
    inset: 18px -18px -18px 18px;
    z-index: -1;
    border: 1px solid rgba(159, 53, 44, 0.32);
    content: "";
  }

  .hero-media img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border: 1px solid rgba(34, 32, 29, 0.24);
    box-shadow: var(--shadow);
    filter: sepia(0.16) saturate(0.86);
  }

  figcaption {
    margin-top: 12px;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .intro {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(280px, 0.52fr);
    gap: clamp(24px, 5vw, 80px);
    padding: 64px 0 34px;
    border-top: 1px solid var(--line);
  }

  .intro h2 {
    max-width: 680px;
    font-size: clamp(2rem, 4vw, 4.2rem);
    line-height: 1;
  }

  .intro p:last-child {
    align-self: end;
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .timeline-shell {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 28px;
    padding: 24px 0 88px;
  }

  .column-head {
    position: sticky;
    top: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 12px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 18px 0;
    background: rgba(244, 239, 230, 0.9);
    backdrop-filter: blur(12px);
  }

  .label-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--red);
  }

  .events-head .label-dot {
    background: var(--blue);
  }

  .column-head h2 {
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .timeline-list {
    display: grid;
    gap: 12px;
    padding-top: 18px;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 14px;
    opacity: 0;
    animation: rise-in 540ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay);
  }

  .date {
    padding-top: 18px;
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  .entry {
    min-height: 142px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--red);
    border-radius: 8px;
    padding: 16px 18px 18px;
    background: rgba(255, 250, 240, 0.72);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .events .entry {
    border-left-color: var(--blue);
  }

  .timeline-item:hover .entry {
    transform: translateY(-2px);
    border-color: rgba(34, 32, 29, 0.3);
    background: var(--paper-strong);
  }

  .era {
    margin: 0 0 10px;
    color: var(--red);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .events .era {
    color: var(--blue);
  }

  .entry h3 {
    font-size: clamp(1.25rem, 2vw, 1.72rem);
    line-height: 1.1;
  }

  .entry p:last-child {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.58;
  }

  footer {
    border-top: 1px solid var(--line);
    padding: 26px 0 42px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  @keyframes rise-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .hero,
    main,
    footer {
      width: min(100% - 24px, 680px);
    }

    .hero {
      min-height: auto;
      padding-bottom: 36px;
    }

    .hero-grid,
    .intro,
    .timeline-shell {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      padding-top: 34px;
    }

    h1 {
      font-size: clamp(3rem, 16vw, 5rem);
    }

    .stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-media::before {
      inset: 12px -10px -10px 10px;
    }

    .hero-media img {
      aspect-ratio: 16 / 11;
    }

    .intro {
      padding-top: 42px;
    }

    .timeline-shell {
      gap: 0;
    }

    .events-head {
      margin-top: 34px;
    }
  }

  @media (max-width: 520px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 6px;
    }

    .date {
      padding-top: 12px;
    }

    .entry {
      min-height: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
